{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "npx tsx .claude/scripts/post-edit-checks.ts" },
          { "type": "command", "command": "npx tsx .claude/scripts/guard-protected-files.ts" }
        ]
      }
    ]
  }
}
